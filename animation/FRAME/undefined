/*# sourceMappingURL=faq-list.component-QVTSYPR5.css.map */</style><script type="application/ld+json" id="json-ld-faq">{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Picflow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Picflow is an online proofing and digital asset management platform for creative professionals. It lets you create branded client galleries, collect feedback through favorites, comments and annotations, manage approvals, and securely share and transfer media files — all in one place."
      }
    },
    {
      "@type": "Question",
      "name": "Who is Picflow for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Picflow is built for photographers, creative agencies, marketing teams, design studios, and any professional who needs to share visual assets and collect client feedback. Whether you&#039;re a freelance photographer delivering wedding galleries or a marketing team reviewing campaign assets, Picflow streamlines your workflow."
      }
    },
    {
      "@type": "Question",
      "name": "Is Picflow free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Picflow offers a free plan with no time limit that includes 2 GB of storage, unlimited galleries, and unlimited collaborators. Paid plans start with a 7-day free trial so you can test the full feature set before committing."
      }
    },
    {
      "@type": "Question",
      "name": "What file types does Picflow support?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Picflow supports all common image formats (JPEG, PNG, TIFF, WEBP, HEIC), RAW files from major camera brands (CR2, CR3, NEF, ARW, DNG, and more), videos (MP4, MOV up to 4K HDR), and audio files. RAW files are automatically converted to high-quality previews."
      }
    },
    {
      "@type": "Question",
      "name": "How does the proofing and approval process work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You upload your assets, create a gallery, and share a branded review link with your client. They can mark favorites, leave comments with annotations directly on images, apply color labels, and set approval statuses — all without needing an account. You get real-time notifications on all activity."
      }
    },
    {
      "@type": "Question",
      "name": "Do clients need an account to review?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Clients and external reviewers can access galleries, leave feedback, and download files without creating an account. You can have unlimited reviewers on any plan — a license is only needed to create and manage galleries."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use my own branding?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can upload your logo, set brand colors, connect a custom domain (e.g., gallery.yourbrand.com), and remove the Picflow badge on paid plans. Every gallery link reflects your brand, not ours."
      }
    },
    {
      "@type": "Question",
      "name": "Does Picflow integrate with my existing tools?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Picflow integrates with Adobe Lightroom Classic, Capture One, Dropbox, Google Drive, Box, and Zapier. You can also embed galleries on any website (WordPress, Webflow, Squarespace, Framer) using our gallery widget, and connect Google Analytics or Google Tag Manager for advanced tracking."
      }
    }
