nTablet":false,"bottomSpacing":"4","hideOnDesktop":false,"customPageWidth":"","mobileTopSpacing":"","mobileBottomSpacing":"","noHorizontalPadding":false}],"blocks":[{"_uid":"e0480c2c-64b1-4627-864f-3050afb2d408","size":"3","type":"h1","style":[{"_uid":"62ba016b-0586-4e32-aaa4-f8391a884da3","component":"block_style","pageWidth":"1","background":"inherit","topSpacing":"0","hideOnMobile":false,"hideOnTablet":false,"bottomSpacing":"1","hideOnDesktop":false,"customPageWidth":"","mobileTopSpacing":"","mobileBottomSpacing":"","noHorizontalPadding":false}],"title":"FAQs","alignment":"center","component":"title","fontWeight":"","customTextAlign":"","mobileAlignment":"","tabletAlignment":"","desktopAlignment":""},{"_uid":"9235f309-99a9-4687-b231-360c8c7251d3","faqs":[{"_uid":"6c2171df-7556-44ed-8013-83b46c69213c","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"Picflow is an online proofing and digital asset management platform for creative professionals. It lets you create branded client galleries, collect feedback through favorites, comments and annotations, manage approvals, and securely share and transfer media files — all in one place.","type":"text"}]}]},"question":"What is Picflow?","component":"faq"},{"_uid":"abf79e22-e01f-42aa-b8a6-06c81e8c95f4","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"Picflow is built for photographers, creative agencies, marketing teams, design studios, and any professional who needs to share visual assets and collect client feedback. Whether you're a freelance photographer delivering wedding galleries or a marketing team reviewing campaign assets, Picflow streamlines your workflow.","type":"text"}]}]},"question":"Who is Picflow for?","component":"faq"},{"_uid":"da0f183b-3004-4a81-a463-5722721d782c","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"Yes. Picflow offers a free plan with no time limit that includes 2 GB of storage, unlimited galleries, and unlimited collaborators. Paid plans start with a 7-day free trial so you can test the full feature set before committing.","type":"text"}]}]},"question":"Is Picflow free to use?","component":"faq"},{"_uid":"0bbb5248-1703-4510-ab90-b5a6683db5c4","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"Picflow supports all common image formats (JPEG, PNG, TIFF, WEBP, HEIC), RAW files from major camera brands (CR2, CR3, NEF, ARW, DNG, and more), videos (MP4, MOV up to 4K HDR), and audio files. RAW files are automatically converted to high-quality previews.","type":"text"}]}]},"question":"What file types does Picflow support?","component":"faq"},{"_uid":"48d5304a-2a97-4fbd-ab4a-fe5a53cb05cf","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"You upload your assets, create a gallery, and share a branded review link with your client. They can mark favorites, leave comments with annotations directly on images, apply color labels, and set approval statuses — all without needing an account. You get real-time notifications on all activity.","type":"text"}]}]},"question":"How does the proofing and approval process work?","component":"faq"},{"_uid":"3d029518-02c5-4534-98d1-b36ceb6a6968","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"No. Clients and external reviewers can access galleries, leave feedback, and download files without creating an account. You can have unlimited reviewers on any plan — a license is only needed to create and manage galleries.","type":"text"}]}]},"question":"Do clients need an account to review?","component":"faq"},{"_uid":"22fd700c-25cf-43d8-909e-b2b2512e023e","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"Yes. You can upload your logo, set brand colors, connect a custom domain (e.g., gallery.yourbrand.com), and remove the Picflow badge on paid plans. Every gallery link reflects your brand, not ours.","type":"text"}]}]},"question":"Can I use my own branding?","component":"faq"},{"_uid":"da96e73e-2afd-4b7d-a863-0825f92016c1","answer":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":null},"content":[{"text":"Yes. Picflow integrates with Adobe Lightroom Classic, Capture One, Dropbox, Google Drive, Box, and Zapier. You can also embed galleries on any website (WordPress, Webflow, Squarespace, Framer) using our gallery widget, and connect Google Analytics or Google Tag Manager for advanced tracking.","type":"text"}]}]},"question":"Does Picflow integrate with my existing tools?","component":"faq"}],"style":[{"_uid":"5dc9b80d-82d0-45f8-9e45-05692e99103e","component":"block_style","pageWidth":"2","background":"inherit","topSpacing":"0","bottomBorder":"","hideOnMobile":false,"hideOnTablet":false,"bottomSpacing":"0","hideOnDesktop":false,"mobileTopSpacing":"","mobileBottomSpacing":"","noHorizontalPadding":false}],"faqStyle":"accordion","component":"faq_list","dynamicFrom":""}],"component":"content_group","alignBlocks":"center"}],"alias":[{"_uid":"458647f2-cd10-40b9-9866-e620ca5ba505","alias":"shotkit","component":"alias"}],"abTest":"","noIndex":false,"topBlur":{"id":null,"alt":null,"name":"","focus":null,"title":null,"source":null,"filename":"","copyright":null,"fieldtype":"asset","meta_data":{}},"affiliate":"","component":"root","keyVisual":{"id":null,"alt":null,"name":"","focus":"","title":null,"source":null,"filename":"https:\u002F\u002Fpicflow.com\u002Fassets\u002Fsharing\u002Fdefault.jpg","copyright":null,"fieldtype":"asset","meta_data":{},"is_external_url":true},"metaTitle":"Picflow — Client Galleries & Online Proofing for Creatives","preFooter":[{"cta":[{"_uid":"746fff0a-6b0c-4459-b6fb-234aeeb4f5a3","link":"\u002Fauth\u002Fsignup","text":"Try Picflow for Free","component":"cta"}],"_uid":"5e0168c1-9967-4f87-a704-19dc9f31becb","image":{